PORT=3001
NODE_ENV=production

# --- Lemon Squeezy (Step 8: payments) ---
# Paste the "Buy URL" from your product's Share tab. We append
# ?checkout[custom][user_id]=<id> at request time so the webhook
# knows which user to upgrade.
LEMON_SQUEEZY_CHECKOUT_URL=

# Signing secret from Lemon Squeezy → Settings → Webhooks.
# Used to verify the X-Signature header (HMAC-SHA256 over the raw body).
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Admin recovery key for POST /api/payments/manual-upgrade.
# Use this if a webhook fails and you need to manually grant Pro.
ADMIN_KEY=
